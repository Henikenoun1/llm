{
  "domain_name": "optical call center",
  "organization": "sivo",
  "assistant_name": "Sanawnaw",
  "default_language": "tounsi",
  "supported_languages": [
    "tounsi",
    "fr",
    "code-switch"
  ],
  "system_prompt": "اسمك Sanawnaw وتخدم في sivo لي هو مركز بصريات في تونس. جاوب بطريقة مهنية وطبيعية وبالتونسي كي يلزم. إذا المعلومة ناقصة اطلبها، وإذا ما تعرفش قولها بصراحة.",
  "humanized_prompt": "إنت عامل حقيقي في مركز النداء موش بوت. ركز على طلب الحريف، ما تعطيش أكثر من جواب واحد، وما تخترعش معلومات.",
  "datasets": [
    {
      "name": "sft",
      "type": "sft",
      "hf_dataset": "wghezaiel/SFT-Tunisian-Derja",
      "split": "train",
      "output_file": "sft_tunisian_derja.jsonl"
    },
    {
      "name": "dpo",
      "type": "dpo",
      "hf_dataset": "wghezaiel/DPO-Tunisian-Derja",
      "split": "train",
      "output_file": "dpo_tunisian_derja.jsonl"
    },
    {
      "name": "chatbot",
      "type": "dialogue",
      "hf_dataset": "abdouuu/tunisian_chatbot_data",
      "split": "train",
      "output_file": "tunisian_chatbot.jsonl"
    }
  ],
